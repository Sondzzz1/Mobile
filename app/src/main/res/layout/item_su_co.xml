<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvPhong"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Phòng 101"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tvTrangThai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa xử lý"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="#F44336"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvLoaiSuCo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Điện"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvMoTa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mô tả sự cố"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNgayBaoGao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="01/01/2024"
            android:textSize="12sp"
            android:textColor="#757575"
            android:drawableStart="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="4dp" />

        <TextView
            android:id="@+id/tvChiPhi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0đ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F44336" />
    </LinearLayout>
</LinearLayout>
