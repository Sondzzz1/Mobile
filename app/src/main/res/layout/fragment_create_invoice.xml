<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:elevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/white"
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="LẬP HÓA ĐƠN"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- BƯỚC 1: CHỌN PHÒNG -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="12dp"
                android:background="@drawable/card_invoice_bg"
                android:elevation="2dp">

                <!-- Header bước 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#F0FAF5">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/colorPrimary"
                        android:text="1"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="CHỌN PHÒNG &amp; THÁNG"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chọn nhà, phòng và tháng lập hóa đơn"
                            android:textColor="@color/textSecondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Tháng -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📅  Tháng lập hóa đơn *"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etMonth"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:drawableEnd="@android:drawable/ic_menu_today"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:textSize="15sp"
                        android:textColor="@color/textPrimary"
                        android:hint="Chọn tháng/năm"/>

                    <!-- Chọn nhà -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏠  Nhà trọ *"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>
                    <Spinner
                        android:id="@+id/spinnerHouse"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Chọn phòng -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚪  Phòng *"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>
                    <Spinner
                        android:id="@+id/spinnerRoom"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Chọn hợp đồng -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📋  Hợp đồng *"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>
                    <Spinner
                        android:id="@+id/spinnerContract"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:paddingHorizontal="14dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- PREVIEW HÓA ĐƠN (ẩn ban đầu) -->
            <LinearLayout
                android:id="@+id/layoutPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="12dp"
                android:background="@drawable/card_invoice_bg"
                android:elevation="2dp"
                android:visibility="gone">

                <!-- Header preview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#FFF8E1">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/colorSecondary"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="CHI TIẾT HÓA ĐƠN"
                            android:textStyle="bold"
                            android:textColor="@color/colorSecondary"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Xem lại trước khi xác nhận"
                            android:textColor="@color/textSecondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FFF3E0"/>

                <!-- Nội dung preview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Thông tin phòng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Phòng"
                            android:textColor="@color/textSecondary"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvPreviewRoom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Khách thuê -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Khách thuê"
                            android:textColor="@color/textSecondary"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvPreviewTenant"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Kỳ hóa đơn -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Kỳ hóa đơn"
                            android:textColor="@color/textSecondary"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvPreviewPeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Đường kẻ nét đứt -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/divider_dashed"
                        android:layout_marginBottom="12dp"/>

                    <!-- Tiền phòng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Tiền phòng"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvPreviewRoomPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Tiền dịch vụ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Tiền dịch vụ"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvPreviewServicePrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Giảm giá -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Giảm giá"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvPreviewDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="#E53935"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Đường kẻ nét đứt -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/divider_dashed"
                        android:layout_marginBottom="12dp"/>

                    <!-- Card tổng tiền -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/card_total_bg"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="TỔNG THANH TOÁN"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:id="@+id/tvPreviewTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="20sp"/>
                    </LinearLayout>

                    <!-- Giảm giá checkbox -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#FFF8E1"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <CheckBox
                            android:id="@+id/cbDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/colorSecondary"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Áp dụng giảm giá"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Nhập số tiền giảm bên dưới"
                                android:textColor="@color/textSecondary"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Ô nhập giảm giá (ẩn ban đầu) -->
                    <LinearLayout
                        android:id="@+id/layoutDiscount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone">
                        <EditText
                            android:id="@+id/etDiscount"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="48dp"
                            android:background="@drawable/edit_text_bg"
                            android:paddingHorizontal="14dp"
                            android:inputType="numberDecimal"
                            android:hint="Số tiền giảm"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="đ"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:background="@color/colorSecondary"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                    </LinearLayout>

                    <!-- Ghi chú -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ghi chú"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etNote"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:background="@drawable/edit_text_bg"
                        android:padding="12dp"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:hint="Ghi chú thêm (nếu có)"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Nút xem trước / xác nhận -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp">

                <Button
                    android:id="@+id/btnPreview"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="XEM TRƯỚC HÓA ĐƠN"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/colorSecondary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp"
                    app:cornerRadius="10dp"/>

                <Button
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="✓  XÁC NHẬN TẠO HÓA ĐƠN"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:cornerRadius="10dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
