<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="#B39DDB"
            android:text="NV"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#B39DDB"/>
            
        <TextView
            android:id="@+id/tvTenantName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Nguyễn Vũ"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/textPrimary"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/date_in"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvDateIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17/03/2026"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/date_out"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvDateOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17/03/2027"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"/>
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang ở"
                android:textColor="#26A69A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvRoomInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="#Việt Tín | P.101"
        android:textColor="@color/textSecondary"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>
        
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

</LinearLayout>
