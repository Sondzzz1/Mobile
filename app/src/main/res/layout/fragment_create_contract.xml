<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="2dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/textPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/create_contract_title"
                android:textAllCaps="true"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp"> <!-- Space for bottom button -->

            <!-- B1: THÔNG TIN HỢP ĐỒNG -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@color/colorSecondary"
                    android:text="B1"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"
                    android:backgroundTint="#26A69A"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b1_title"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b1_desc"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:textStyle="italic"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chọn nhà *"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/spinnerHouse"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/select_room"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/spinnerRoom"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/start_date"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:drawableEnd="@android:drawable/ic_menu_today"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp"
                    android:focusable="false"
                    android:clickable="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/end_date"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:drawableEnd="@android:drawable/ic_menu_today"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp"
                    android:focusable="false"
                    android:clickable="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/room_price_req"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/etRoomPrice"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:background="@drawable/edit_text_bg"
                        android:paddingHorizontal="12dp"
                        android:inputType="number"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="/tháng"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:background="@color/colorSecondary"
                        android:textColor="@color/white"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/deposit_req"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etDeposit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="number"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_cycle"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/spinnerPaymentCycle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/closing_date"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/closing_date_hint"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/spinnerClosingDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/paid_until"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/paid_until_hint"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etPaidUntil"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:drawableEnd="@android:drawable/ic_menu_today"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp"
                    android:focusable="false"
                    android:clickable="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE"/>

            <!-- B2: THÔNG TIN KHÁCH THUÊ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@color/colorSecondary"
                    android:text="B2"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"
                    android:backgroundTint="#2E7D32"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b2_title"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b2_desc"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:textStyle="italic"/>
                </LinearLayout>
            </LinearLayout>
            
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/phone_req"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="phone"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/fullname_req"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/workplace"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etWorkplace"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textCapWords"
                    android:hint="Nơi làm việc"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/email"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dob"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etDob"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:drawableEnd="@android:drawable/ic_menu_today"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp"
                    android:focusable="false"
                    android:clickable="true"/>
                    
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/id_card"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etIdCard"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="number"
                    android:layout_marginBottom="16dp"/>
                    
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/issue_date"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etIssueDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="text"
                    android:hint="Ngày cấp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/issue_place"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etIssuePlace"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textCapWords"
                    android:hint="Nơi cấp"
                    android:layout_marginBottom="16dp"/>
                    
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/province"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etProvince"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textCapWords"
                    android:hint="Tỉnh/Thành phố"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quận/Huyện"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etDistrict"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textCapWords"
                    android:hint="Quận/Huyện"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ward"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etWard"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textCapWords"
                    android:hint="Xã/Phường"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/detailed_address"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etDetailedAddress"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:inputType="textCapSentences"
                    android:hint="Địa chỉ chi tiết"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/note"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/collapse"
                    android:textColor="@color/colorSecondary"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
            
            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE"/>

            <!-- B3: DỊCH VỤ SỬ DỤNG -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@color/colorSecondary"
                    android:text="B3"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"
                    android:backgroundTint="#039BE5"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b3_title"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b3_desc"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:textStyle="italic"/>
                </LinearLayout>
            </LinearLayout>
            
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_note"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:hint="Ghi chú: Giảm giá 3 tháng đầu..."
                    android:paddingHorizontal="12dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE"/>

            <!-- B4: XÁC NHẬN ĐIỀU KHOẢN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@color/colorSecondary"
                    android:text="B4"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginEnd="12dp"
                    android:backgroundTint="#8E24AA"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b4_title"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/b4_desc"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:textStyle="italic"/>
                </LinearLayout>
            </LinearLayout>
            
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/view_terms"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        android:rotation="180"
                        app:tint="@color/textSecondary"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        android:elevation="8dp"
        android:padding="16dp">
        
        <Button
            android:id="@+id/btnCreateContract"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/create_contract_title"
            android:textColor="@color/white"
            android:backgroundTint="@color/colorSecondary"
            android:textStyle="bold"
            app:cornerRadius="8dp"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
