<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TẠO HỢP ĐỒNG THUÊ PHÒNG"
            android:textColor="@color/colorPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Thông tin khách thuê -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN KHÁCH THUÊ"
                android:textColor="@color/colorSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvTenantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Họ tên: Nguyễn Văn A"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvTenantPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SĐT: 0987654321"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvTenantIdCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CMND/CCCD: 001234567890"
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvRoomName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phòng: Phòng 101"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Ngày bắt đầu -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày bắt đầu *"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etStartDate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="12dp"
            android:hint="dd/MM/yyyy"
            android:drawableEnd="@android:drawable/ic_menu_today"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="16dp"/>

        <!-- Thời hạn -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thời hạn hợp đồng *"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <EditText
                android:id="@+id/etDuration"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:paddingHorizontal="12dp"
                android:hint="12"
                android:inputType="number"
                android:text="12"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="tháng"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- Ngày kết thúc (tự động tính) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày kết thúc (tự động)"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:id="@+id/tvEndDate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:text="26/03/2027"
            android:textColor="@color/textPrimary"
            android:layout_marginBottom="16dp"/>

        <!-- Giá thuê -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Giá thuê/tháng *"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <EditText
                android:id="@+id/etPrice"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:paddingHorizontal="12dp"
                android:hint="1800000"
                android:inputType="number"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="đ"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="@color/textSecondary"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Tiền đặt cọc -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tiền đặt cọc"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <EditText
                android:id="@+id/etDeposit"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:paddingHorizontal="12dp"
                android:hint="0"
                android:inputType="number"
                android:text="0"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="đ"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:textColor="@color/textSecondary"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Ghi chú -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ghi chú"
            android:textColor="@color/textPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etContractNote"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:hint="Ghi chú thêm về hợp đồng..."
            android:gravity="top"
            android:inputType="textMultiLine|textCapSentences"
            android:layout_marginBottom="16dp"/>

        <!-- Cảnh báo nếu là người ở ghép -->
        <TextView
            android:id="@+id/tvRoommateWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Hợp đồng cho người ở ghép"
            android:textColor="@color/error"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
