<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#26A69A"
        app:elevation="0dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btnBack"
                android:layout_marginStart="16dp"
                android:layout_centerVertical="true"
                android:text="@string/utility_title"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLock"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:backgroundTint="@color/colorSecondary"
                android:text="@string/btn_lock"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="4dp" />
        </RelativeLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutMonths"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#26A69A"
            app:tabIndicatorColor="#1E88E5"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabSelectedTextColor="#212121"
            app:tabTextColor="@color/white"
            android:visibility="gone">

            <!-- Example tabs, in real app set programmatically -->
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/2026" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="02/2026" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="03/2026" />
        </com.google.android.material.tabs.TabLayout>
        
        <!-- CẢI TIẾN 3: Bộ lọc nhà/phòng/tháng/năm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#26A69A">
            
            <!-- Hàng 1: Nhà và Phòng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                
                <Spinner
                    android:id="@+id/spinnerHouse"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="8dp"/>
                
                <Spinner
                    android:id="@+id/spinnerRoom"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="8dp"/>
            </LinearLayout>
            
            <!-- Hàng 2: Tháng và Năm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Spinner
                    android:id="@+id/spinnerThang"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="8dp"/>
                
                <Spinner
                    android:id="@+id/spinnerNam"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="8dp"/>
                
                <Button
                    android:id="@+id/btnXemTatCa"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Tất cả"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/colorSecondary"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    app:cornerRadius="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:background="@drawable/bottom_rounded_corners" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/utilityContentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Empty State View -->
        <LinearLayout
            android:id="@+id/emptyStateView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#81D4FA"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chua co du lieu"
                android:textColor="@color/textSecondary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Data Table View -->
        <LinearLayout
            android:id="@+id/dataTableView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            android:background="@drawable/border_unselected"
            android:visibility="visible">

            <!-- House Title Row -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Việt Tín"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/textPrimary" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Table Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/header_room"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/textPrimary" />
                    
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1.2"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/header_electric"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/textPrimary" />
                    
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1.2"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="@string/header_water"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/textPrimary" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- RecyclerView for Data Rows -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerUtility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </FrameLayout>
</LinearLayout>
