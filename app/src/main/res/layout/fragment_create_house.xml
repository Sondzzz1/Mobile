<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            android:paddingHorizontal="16dp"
            android:elevation="2dp">
            
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/textPrimary"
                android:layout_centerVertical="true"
                android:contentDescription="Quay về"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý nhà trọ"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/surface"
            android:layout_margin="8dp">

            <!-- Tên nhà trọ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên nhà trọ *"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etHouseName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Nhập tên nhà trọ"
                android:inputType="textCapSentences"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- Tên chủ nhà -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên chủ nhà"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etOwnerName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Nhập tên chủ nhà"
                android:inputType="textCapWords"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- Số điện thoại -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Số điện thoại"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etOwnerPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Nhập số điện thoại"
                android:inputType="phone"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>

        <!-- Địa chỉ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/surface"
            android:layout_margin="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ĐỊA CHỈ"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Địa chỉ cụ thể -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Địa chỉ cụ thể"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Số nhà, tên đường..."
                android:inputType="textCapSentences"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- Xã/Phường -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Xã/Phường"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etWard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Nhập xã/phường"
                android:inputType="textCapWords"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- Quận/Huyện -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quận/Huyện"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etDistrict"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Nhập quận/huyện"
                android:inputType="textCapWords"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- Tỉnh/Thành phố -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tỉnh/Thành phố"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etProvince"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Nhập tỉnh/thành phố"
                android:inputType="textCapWords"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

            <!-- Ghi chú -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ghi chú"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/edit_text_bg"
                android:hint="Nhập ghi chú (nếu có)"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>

        <!-- Nút lưu -->
        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Lưu nhà trọ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:layout_margin="16dp"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
