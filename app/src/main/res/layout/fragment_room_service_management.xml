<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:elevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white"
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="DỊCH VỤ PHÒNG"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hướng dẫn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#E3F2FD"
                android:padding="12dp"
                android:layout_margin="12dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Chọn nhà và phòng, sau đó tick chọn các dịch vụ mà phòng đó sử dụng. Các dịch vụ được chọn sẽ tự động tính vào hóa đơn hàng tháng."
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Chọn nhà -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_invoice_bg"
                android:padding="16dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏠  Chọn nhà trọ"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                
                <Spinner
                    android:id="@+id/spinnerHouse"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="14dp"/>
            </LinearLayout>

            <!-- Chọn phòng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_invoice_bg"
                android:padding="16dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚪  Chọn phòng"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                
                <Spinner
                    android:id="@+id/spinnerRoom"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="14dp"/>
            </LinearLayout>

            <!-- Tiêu đề danh sách dịch vụ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📦  Dịch vụ phòng sử dụng"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginTop="4dp"/>

            <!-- Danh sách dịch vụ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDichVuPhong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingBottom="16dp"/>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/layoutEmptyService"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="48sp"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tvHuongDan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn nhà và phòng để xem dịch vụ"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
